# Copy this file to .env and fill in the values before running anything:
#   cp .env.example .env
# .env is gitignored — never commit real secrets.

# --- LLM provider ---------------------------------------------------------
# Required unless you're using the Ollama fallback below.
# Get a free key at https://console.groq.com -> API Keys -> Create API Key.
GROQ_API_KEY=

# Optional local fallback, used automatically when GROQ_API_KEY is empty
# (e.g. offline demo). Requires Ollama installed (https://ollama.com) and
# the model pulled: `ollama pull llama3.1:8b`.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# --- Neo4j (knowledge graph) ----------------------------------------------
# Started locally via `docker compose up -d` (see docker-compose.yml).
# Browser UI: http://localhost:7474 — login with the user/password below.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# --- Retrieval / RAG tuning (feat/production-stack) ------------------------
# All optional — unset values keep the original dense-only behavior. Set to
# 1/true to enable. Every feature degrades gracefully if its package or the
# backing service is missing (logged, never fatal).
#
# Hybrid search: BM25 (lexical, great for exact tags like P-101 / 29 CFR ...)
# fused with dense vectors via Reciprocal Rank Fusion. Big accuracy win on
# industrial docs full of part numbers and regulation codes.
HYBRID_SEARCH=1
# Cross-encoder reranker (flashrank) over the fused candidates before generation.
RERANK=1
RERANK_MODEL=ms-marco-MiniLM-L-12-v2
# Candidate pool pulled before rerank/fusion trims back down to top_k.
RETRIEVE_CANDIDATES=30
# Entity extraction backend for the KG: "gliner" (fast encoder NER, no LLM
# tokens) or "llm" (original per-chunk LLM call). "gliner" unblocks graph
# ingestion when the Groq daily token cap is exhausted.
ENTITY_BACKEND=gliner
GLINER_MODEL=urchade/gliner_medium-v2.1

# --- LLM gateway (LiteLLM, feat/production-stack) --------------------------
# When set, llm_client routes through LiteLLM with an automatic fallback chain
# (primary -> fallback) plus retries/backoff, instead of calling one provider
# directly. Leave USE_LITELLM unset to keep the original groq/ollama path.
USE_LITELLM=1
LITELLM_MODEL=groq/llama-3.3-70b-versatile
LITELLM_FALLBACK_MODEL=ollama/llama3.1:8b
# Hard ceiling on LLM output tokens per day across the whole app (0 = no cap).
# Guards against silently blowing the Groq free-tier 100k/day limit.
LLM_DAILY_TOKEN_BUDGET=0

# --- Observability (Langfuse, optional) ------------------------------------
# Leave blank to disable tracing entirely (the wrapper becomes a no-op).
# Self-host or use cloud.langfuse.com; keys from your Langfuse project settings.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Chroma (vector store) -------------------------------------------------
# Runs embedded, no server/container needed — this is just a local folder
# chromadb writes its index to. Safe to delete to reset the index.
CHROMA_PATH=./chroma_db

# --- Backend API ------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# --- Frontend ----------------------------------------------------------------
# Must match API_HOST/API_PORT above so the frontend can reach the backend.
VITE_API_BASE_URL=http://localhost:8000
