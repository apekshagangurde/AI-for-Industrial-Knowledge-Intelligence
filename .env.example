# Copy this file to .env and fill in the values before running anything:
#   cp .env.example .env
# .env is gitignored — never commit real secrets.

# --- LLM provider ---------------------------------------------------------
# Required unless you're using the Ollama fallback below.
# Get a free key at https://console.groq.com -> API Keys -> Create API Key.
GROQ_API_KEY=

# Optional local fallback, used automatically when GROQ_API_KEY is empty
# (e.g. offline demo). Requires Ollama installed (https://ollama.com) and
# the model pulled: `ollama pull llama3.1:8b`.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# --- Neo4j (knowledge graph) ----------------------------------------------
# Started locally via `docker compose up -d` (see docker-compose.yml).
# Browser UI: http://localhost:7474 — login with the user/password below.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# --- Chroma (vector store) -------------------------------------------------
# Runs embedded, no server/container needed — this is just a local folder
# chromadb writes its index to. Safe to delete to reset the index.
CHROMA_PATH=./chroma_db

# --- Backend API ------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# --- Frontend ----------------------------------------------------------------
# Must match API_HOST/API_PORT above so the frontend can reach the backend.
VITE_API_BASE_URL=http://localhost:8000
