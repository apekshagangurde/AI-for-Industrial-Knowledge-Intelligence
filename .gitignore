# Environment
.env
.env.local

# Python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/

# Node / frontend
node_modules/
frontend/dist/
frontend/.vite/

# Data
# raw/ is committed: small (~5MB), public-domain/CC-licensed seed docs (see
# manifest.csv), and keeping them in-repo means the corpus doesn't depend on
# external sites staying up during the hackathon.
data/synthetic/*
!data/synthetic/.gitkeep
data/processed/*
!data/processed/.gitkeep

# Vector DB / graph local state
chroma_db/
neo4j_data/

# OS / editor
.DS_Store
.vscode/
.idea/

# Backend virtualenv
backend/.venv/
backend/.pytest_cache/

# Frontend
frontend/node_modules/
frontend/dist/
