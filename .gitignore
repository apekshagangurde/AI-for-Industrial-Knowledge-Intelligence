# Environment
.env
.env.local

# Python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/

# Node / frontend
node_modules/
frontend/dist/
frontend/.vite/

# Data
# raw/ and synthetic/ are committed (small, <100KB-few MB): raw/ so the corpus
# doesn't depend on external sites staying up, synthetic/ so every teammate
# demos against the same "Plant Alpha" narrative instead of a fresh
# LLM-regenerated one. processed/ is pipeline output — always regenerable.
data/processed/*
!data/processed/.gitkeep

# Vector DB / graph local state
chroma_db/
neo4j_data/
backend/entity_cache.json

# OS / editor
.DS_Store
.vscode/
.idea/

# Backend virtualenv
backend/.venv/
backend/.pytest_cache/

# Frontend
frontend/node_modules/
frontend/dist/
